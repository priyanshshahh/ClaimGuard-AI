# --- Frontend (copy to frontend/.env.local) ---
# Base URL the Next.js app fetches the backend at. This is the only frontend
# env var, and the only one Next.js exposes to client-side code (Next.js only
# ever exposes NEXT_PUBLIC_-prefixed vars to the browser).
#
# Backend + training env vars live in backend/.env.example.
NEXT_PUBLIC_API_URL=http://localhost:8000
