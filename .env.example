# ClaimGuard-AI environment variables (repo root)
# Copy to backend/.env for the API, frontend/.env.local for Next.js.

# --- Frontend (frontend/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# Opt-in demo theater (seed claims, simulated EHR lab). Default off in production.
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend auth & storage ---
# Local dev / CI: skip JWT and API keys
AUTH_DISABLED=true
# Comma-separated API keys (when AUTH_DISABLED=false)
API_KEYS=
API_KEY_ORG_ID=local
DEFAULT_ORG_ID=
SUPABASE_JWT_SECRET=

# duckdb (default) or postgres
STORAGE_BACKEND=duckdb
DUCKDB_PATH=data/claims.duckdb
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/claimguard

# --- LLM agent ---
GROQ_API_KEY=
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/
NEBIUS_MODEL=google/gemma-3-27b-it
LLM_TIMEOUT=20

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
# Optional regex for preview deploys; leave empty in production unless needed
CORS_ORIGIN_REGEX=

# --- Model artifacts ---
MODELS_DIR=backend/models
OVERTURN_RATE=0.5
LOG_LEVEL=INFO

# --- Training (scripts/train.py) ---
WANDB_API_KEY=
WANDB_PROJECT=claimguard-denial-model
WANDB_MODE=disabled
