# Backend env subset — see repo-root .env.example for the full list.
# Copy root .env.example to backend/.env for local development.

AUTH_DISABLED=true
STORAGE_BACKEND=duckdb
DUCKDB_PATH=data/claims.duckdb
DATABASE_URL=
API_KEYS=
SUPABASE_JWT_SECRET=
