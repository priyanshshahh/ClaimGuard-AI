# --- Backend (copy to backend/.env) ---
#
# Frontend env vars live in the repo-root .env.example.

# LLM providers for the clinical-notes agent. Groq is the default path;
# Nebius is optional and tried first when set. With neither key set the API
# still runs: model scoring works, agent analysis returns a labeled fallback.
GROQ_API_KEY=
NEBIUS_API_KEY=
NEBIUS_MODEL=google/gemma-3-27b-it

# Hard timeout (seconds) for every LLM HTTP call so a hung provider connection
# is bounded instead of wedging the request.
LLM_TIMEOUT=20

# CORS. Exact origins (comma-separated) + one regex for preview deployments.
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Claims storage (DuckDB file, created on first write)
DUCKDB_PATH=data/claims.duckdb

# Model artifacts directory (committed artifacts by default)
# MODELS_DIR=models

# --- Training (scripts/train.py) ---
# W&B is optional: offline by default, set an API key to sync online,
# WANDB_MODE=disabled to turn it off entirely.
WANDB_API_KEY=
WANDB_PROJECT=claimguard-denial-model
